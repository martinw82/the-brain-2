# THE BRAIN — Environment Variables
# Copy this to .env and fill in your values

# ===========================================
# DATABASE (TiDB Cloud recommended)
# ===========================================
DB_HOST=your-host.prod.aws.tidbcloud.com
DB_PORT=4000
DB_USER=your-username
DB_PASSWORD=your-password
DB_NAME=the_brain

# ===========================================
# AUTH
# ===========================================
JWT_SECRET=your-secure-random-secret-at-least-32-chars

# ===========================================
# AI PROVIDERS (at least one required)
# ===========================================
# Anthropic (Claude) - Recommended
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT)
OPENAI_API_KEY=sk-...

# Moonshot (Kimi)
MOONSHOT_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Mistral
MISTRAL_API_KEY=
