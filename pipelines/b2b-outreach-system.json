{
  "pipeline_id": "b2b-outreach-system",
  "version": "1.0",
  "name": "Trade/Construction B2B Outreach",
  "description": "Personalized cold email outreach with strict tone enforcement",
  "project_type": "B2B_OUTREACH",
  "variant": "paid",
  "created": "2026-03-25",
  
  "stages": [
    {
      "stage_id": "lead_research",
      "name": "Lead Research",
      "agent": "system-outreach-trade",
      "worker_type": "websocket",
      "capabilities_required": ["browser", "playwright"],
      "inputs": {
        "lead_list": "target_companies.csv"
      },
      "outputs": [
        "researched_leads"
      ],
      "research_sources": [
        "company_website",
        "linkedin",
        "local_news",
        "companies_house"
      ],
      "success_criteria": "Each lead has verifiable facts"
    },
    {
      "stage_id": "email_draft",
      "name": "Email Draft",
      "agent": "system-outreach-trade",
      "worker_type": "cli_subprocess",
      "capabilities_required": ["shell"],
      "inputs": [
        "researched_leads"
      ],
      "outputs": [
        "email_drafts"
      ],
      "constraints": {
        "max_words": 200,
        "max_paragraphs": 3,
        "forbidden_words": ["solution", "synergy", "leverage", "holistic", "going forward", "reach out"],
        "required_elements": ["specific_verifiable_fact"]
      },
      "success_criteria": "All constraints met, forbidden words absent"
    },
    {
      "stage_id": "gate_1",
      "name": "Trust Gate: Approve Email",
      "type": "trust_gate",
      "gate_name": "approve_email",
      "tier": 1,
      "approval_mode": "individual",
      "notes": "Every email individually reviewed at Tier 1",
      "inputs": [
        "email_drafts"
      ],
      "approval_criteria": [
        "Tone appropriate",
        "Specific fact included",
        "No forbidden words",
        "CTA clear"
      ],
      "success_criteria": "Approved or rejected with notes"
    },
    {
      "stage_id": "send",
      "name": "Send Email",
      "type": "integration",
      "integration": "domain_smtp",
      "inputs": [
        "approved_emails"
      ],
      "outputs": [
        "sent_confirmations"
      ],
      "rate_limit": "20_per_hour",
      "success_criteria": "Email sent, logged in REL"
    },
    {
      "stage_id": "crm_update",
      "name": "CRM Update",
      "type": "rel_update",
      "actions": [
        "update lead status: email_sent",
        "set awaits_reply_by: +72h",
        "link to thread entity"
      ],
      "status_chain": "lead → email_draft → email_sent"
    }
  ],
  
  "trust_ladder": {
    "tier_1_gates": ["approve_email"],
    "tier_2_gates": ["approve_email"],
    "tier_3_gates": [],
    "notes": "Tier 3 never achieved - every email requires human review for reputation protection"
  },
  
  "session_continuity": {
    "enabled": true,
    "follow_up_trigger": "72h_no_reply",
    "follow_up_agent": "system-inbound-monitor",
    "thread_tracking": "awaits_reply_by edge in REL"
  },
  
  "infrastructure": {
    "outbound": "domain_smtp",
    "inbound": "gmail_api",
    "rate_limits": {
      "smtp": "100_per_day",
      "gmail_api": "standard_quota"
    }
  }
}
