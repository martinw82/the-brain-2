{
  "pipeline_id": "video-auto-pipeline",
  "version": "1.0",
  "name": "YouTube Long-Form Documentary Factory",
  "description": "10-30 minute documentary video production with segmented architecture",
  "project_type": "YOUTUBE",
  "variant": "hybrid",
  "format": "long_form",
  "created": "2026-03-25",
  
  "stages": [
    {
      "stage_id": "research",
      "name": "Topic Research",
      "agent": "system-youtube-research",
      "provider": "claude-sonnet",
      "fallback": "claude-haiku",
      "inputs": {
        "topic": "user_provided",
        "target_duration": "18-22_minutes"
      },
      "outputs": [
        "research_data",
        "hook_angles",
        "key_facts"
      ],
      "cost_estimate_gbp": 0.05,
      "success_criteria": "8-12 facts with sources, 3 hook angles"
    },
    {
      "stage_id": "assessment",
      "name": "Dynamic Assessment",
      "agent": "system-assessment-v1",
      "type": "assessment",
      "inputs": [
        "research_data"
      ],
      "outputs": [
        "execution_manifest"
      ],
      "routing_decisions": [
        "provider_selection",
        "worker_assignment",
        "cost_budget"
      ],
      "success_criteria": "Manifest generated with confidence > 0.8"
    },
    {
      "stage_id": "outline",
      "name": "4-Act Outline",
      "agent": "system-youtube-script",
      "provider": "claude-sonnet",
      "type": "outline",
      "structure": "mystery → discovery → evidence → modern_relevance",
      "inputs": [
        "research_data"
      ],
      "outputs": [
        "narrative_outline"
      ],
      "success_criteria": "Clear arc with segment breaks"
    },
    {
      "stage_id": "script",
      "name": "Segmented Script",
      "agent": "system-youtube-script",
      "provider": "claude-sonnet",
      "type": "script",
      "segments": {
        "count": "4-6",
        "words_per_segment": "600-900",
        "duration_per_segment": "5-7_minutes"
      },
      "inputs": [
        "narrative_outline",
        "research_data"
      ],
      "outputs": [
        "script_segments",
        "visual_cues"
      ],
      "cost_estimate_gbp": 0.10,
      "success_criteria": "All segments complete with [V: cues]"
    },
    {
      "stage_id": "keywords",
      "name": "SEO Optimization",
      "agent": "system-youtube-keywords",
      "provider": "claude-haiku",
      "inputs": [
        "script_segments"
      ],
      "outputs": [
        "title_options",
        "description",
        "tags",
        "chapter_timestamps"
      ],
      "success_criteria": "Title < 60 chars, description > 800 words"
    },
    {
      "stage_id": "gate_1",
      "name": "Trust Gate: Approve Script",
      "type": "trust_gate",
      "gate_name": "approve_script",
      "tier": 1,
      "notes": "Gate 1: Script approval saves render cost if rejected",
      "approval_criteria": [
        "Factual accuracy",
        "Tone appropriate",
        "Hook strength",
        "Segment flow"
      ],
      "inputs": [
        "script_segments",
        "title_options",
        "description"
      ]
    },
    {
      "stage_id": "storyboard",
      "name": "Visual Storyboard",
      "agent": "system-youtube-storyboard",
      "provider": "claude-haiku",
      "inputs": [
        "approved_script"
      ],
      "outputs": [
        "storyboard_json",
        "asset_specifications"
      ],
      "scene_constraints": {
        "min_duration_s": 3,
        "max_duration_s": 8,
        "max_per_segment": 60
      },
      "cost_estimate_gbp": 0.05,
      "success_criteria": "All scenes mapped with asset specs"
    },
    {
      "stage_id": "retention",
      "name": "Retention Optimization",
      "agent": "system-youtube-retention",
      "provider": "claude-haiku",
      "inputs": [
        "storyboard_json"
      ],
      "outputs": [
        "retention_notes",
        "hook_injections",
        "transition_bridges"
      ],
      "success_criteria": "Hook every 90 seconds"
    },
    {
      "stage_id": "gate_2",
      "name": "Trust Gate: Approve Storyboard",
      "type": "trust_gate",
      "gate_name": "approve_storyboard",
      "tier": 1,
      "inputs": [
        "storyboard_json",
        "retention_notes"
      ],
      "approval_criteria": [
        "Visual plan clear",
        "Asset sourcing feasible",
        "Cost acceptable"
      ]
    },
    {
      "stage_id": "asset_sourcing",
      "name": "Asset Sourcing (Parallel)",
      "type": "parallel_worker_tasks",
      "tasks": [
        {
          "name": "stock_footage",
          "sources": ["pexels", "pixabay", "coverr"],
          "priority": 1
        },
        {
          "name": "generated_stills",
          "provider": "fal-flux-schnell",
          "cost_per_image_gbp": 0.002,
          "priority": 2
        },
        {
          "name": "voiceover",
          "provider": "edge-tts",
          "fallback": "elevenlabs",
          "priority": 1
        },
        {
          "name": "captions",
          "provider": "whisper-replicate",
          "cost_per_minute_gbp": 0.006,
          "priority": 2
        }
      ],
      "inputs": [
        "approved_storyboard"
      ],
      "outputs": [
        "collected_assets"
      ],
      "cost_estimate_gbp": 0.40,
      "success_criteria": "All assets collected with checksums"
    },
    {
      "stage_id": "assembly",
      "name": "Video Assembly",
      "worker_type": "cli_subprocess",
      "capabilities_required": ["shell", "node", "remotion"],
      "pre_flight": [
        "npm install -g remotion@latest"
      ],
      "main_command": "npx remotion render --props='{storyboard_json}' composition.tsx Documentary /output/video.mp4",
      "inputs": [
        "collected_assets",
        "script_segments"
      ],
      "outputs": [
        "video_file"
      ],
      "fallback": {
        "strategy": "ffmpeg",
        "condition": "remotion_fails"
      },
      "success_criteria": "Video rendered, duration matches target"
    },
    {
      "stage_id": "gate_3",
      "name": "Trust Gate: Pre-Upload Review",
      "type": "trust_gate",
      "gate_name": "pre_upload_review",
      "tier": 1,
      "inputs": [
        "video_file",
        "thumbnail"
      ],
      "approval_criteria": [
        "Video quality acceptable",
        "Audio clear",
        "Captions accurate",
        "Thumbnail compelling"
      ]
    },
    {
      "stage_id": "upload",
      "name": "YouTube Upload",
      "integration": "youtube_api",
      "inputs": [
        "approved_video",
        "title",
        "description",
        "tags",
        "thumbnail"
      ],
      "outputs": [
        "youtube_video_id",
        "public_url"
      ],
      "privacy": "public",
      "success_criteria": "Video live on YouTube"
    }
  ],
  
  "trust_ladder": {
    "tier_1_gates": ["approve_script", "approve_storyboard", "pre_upload_review"],
    "tier_2_gates": ["approve_storyboard", "pre_upload_review"],
    "tier_3_gates": ["pre_upload_review"],
    "target_tier": 2,
    "target_timeline": "Month 2: Gate 1 at Tier 2"
  },
  
  "cost_controls": {
    "per_video_target_gbp": 0.20,
    "per_video_max_gbp": 0.50,
    "monthly_budget_gbp": 15,
    "alert_threshold": 0.8
  },
  
  "quality_targets": {
    "resolution": "1920x1080",
    "fps": 30,
    "audio_quality": "48khz_stereo",
    "target_cpm_usd": "8-15"
  }
}
